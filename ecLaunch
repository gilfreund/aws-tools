#!/usr/bin/env bash
# shellcheck source=./tools.rc
_TOOLS_RC="${0%/*}/tools.rc"
if [[ ! -f "$_TOOLS_RC" ]]; then
  echo "ERROR: tools.rc not found at $_TOOLS_RC"
  echo "Ensure tools.rc is in the same directory as ecLaunch."
  exit 1
fi
source "$_TOOLS_RC"

EC_NAME_PREFIX="${EC_NAME_PREFIX:-compute-}"

if [[ -n "$EC_LAUNCH_TEMPLATE_NAME" ]]; then
  # Default ignore list for launch template listing (space-separated glob patterns)
  EC_LAUNCH_TEMPLATE_IGNORE="${EC_LAUNCH_TEMPLATE_IGNORE:-Batch-lt* agc*}"

  # Resolve launch template ID from EC_LAUNCH_TEMPLATE_NAME, validate it exists
  _LAUNCHTEMPLATE=$(aws ec2 describe-launch-templates \
      --launch-template-names "$EC_LAUNCH_TEMPLATE_NAME" \
      --query "LaunchTemplates[].LaunchTemplateId" \
      --output text 2>/dev/null) || true

  if [[ -z "$_LAUNCHTEMPLATE" ]]; then
    echo "WARNING: Launch template '$EC_LAUNCH_TEMPLATE_NAME' not found."

    _ignoreFilter=""
    for _pattern in $EC_LAUNCH_TEMPLATE_IGNORE; do
      _ignoreFilter="${_ignoreFilter}&&!starts_with(LaunchTemplateName,\`${_pattern%\*}\`)"
    done
    _ignoreFilter="${_ignoreFilter#&&}"

    echo "Available launch templates:"
    aws ec2 describe-launch-templates \
      --query "LaunchTemplates[?${_ignoreFilter}].[LaunchTemplateName,LaunchTemplateId,DefaultVersionNumber]" \
      --output table

    read -rp "Enter the correct launch template name (or press Enter to launch without a template): " _ltInput
    if [[ -n "$_ltInput" ]]; then
      EC_LAUNCH_TEMPLATE_NAME="$_ltInput"
      _LAUNCHTEMPLATE=$(aws ec2 describe-launch-templates \
          --launch-template-names "$EC_LAUNCH_TEMPLATE_NAME" \
          --query "LaunchTemplates[].LaunchTemplateId" \
          --output text 2>/dev/null) || true
      if [[ -z "$_LAUNCHTEMPLATE" ]]; then
        echo "Launch template '$EC_LAUNCH_TEMPLATE_NAME' still not found, exiting."
        exit 1
      fi
    else
      echo "Proceeding without a launch template."
      EC_LAUNCH_TEMPLATE_NAME=""
    fi
  fi

  if [[ -n "$_LAUNCHTEMPLATE" ]]; then
    # shellcheck disable=SC2016
    EC_LAUNCH_TEMPLATE_VERSION="${EC_LAUNCH_TEMPLATE_VERSION:-\$Default}"
    _LAUNCHTEMPLATEARG="--launch-template LaunchTemplateId=${_LAUNCHTEMPLATE},Version=${EC_LAUNCH_TEMPLATE_VERSION}"
  fi
else
  echo "No launch template configured, launching with direct parameters only."
fi

# Usage output
usage() {
  echo "Usage: ${BASH_SOURCE[0]} [ -t | --type TYPE ] [ -o | --owner OWNER ] [ -a | --ami AMI ] [ -s | --subnet SUBNET-ID ] [ -v | --vpc VPC-ID ] [ -T | --tag Key=Value ] [ --replace-tags ] [ -n | --dry-run ] [ -p | --profile PROFILE ] [ --list-subnets ] [ -h | --help ]
        -t | --type TYPE         EC2 instance type (e.g. t3.medium)
        -o | --owner OWNER       Owner tag value (default: current user)
        -a | --ami AMI           AMI ID or '2023' for latest Amazon Linux 2023 (default: 2023)
        -s | --subnet SUBNET-ID  Subnet ID to launch into (overrides EC_SUBNET_ID and EC_SUBNET_FILTER)
        -v | --vpc VPC-ID        VPC ID to use (overrides EC_VPC_ID and EC_VPC_FILTER)
        -T | --tag Key=Value     Additional tag to apply (may be repeated; appends to EC_EXTRA_TAGS by default)
        --replace-tags           Replace EC_EXTRA_TAGS entirely with tags from -T flags
        -n | --dry-run           Print the aws run-instances command without executing it
        -p | --profile PROFILE   AWS config profile to use (overrides EC_AWS_PROFILE from config)
        --list-subnets           List available subnets matching the current filter and exit
        -h | --help              Show this help"
  exit 0
}

# Get viable subnets based on EC_SUBNET_FILTER scoped to _VPC_ID if set
_getSubnets() {
  local _filter="${EC_SUBNET_FILTER:-*rivate*}"
  local _filters=("Name=tag:Name,Values=$_filter")
  [[ -n "${_VPC_ID:-}" ]] && _filters+=("Name=vpc-id,Values=$_VPC_ID")
  aws --output text ec2 describe-subnets \
    --filters "${_filters[@]}" \
    --query "Subnets[*].[SubnetId,AvailabilityZone,CidrBlock,Tags[?Key=='Name']|[0].Value]"
}

# List subnets in a readable table
_listSubnets() {
  local _filter="${EC_SUBNET_FILTER:-*rivate*}"
  local _filters=("Name=tag:Name,Values=$_filter")
  [[ -n "${_VPC_ID:-}" ]] && _filters+=("Name=vpc-id,Values=$_VPC_ID")
  echo "Available subnets (filter: Name='$_filter'${_VPC_ID:+, VPC=$_VPC_ID}):"
  aws --output table ec2 describe-subnets \
    --filters "${_filters[@]}" \
    --query "Subnets[*].{ID:SubnetId,AZ:AvailabilityZone,CIDR:CidrBlock,Name:Tags[?Key=='Name']|[0].Value}"
}

# Resolve VPC: EC_VPC_ID > EC_VPC_FILTER > single VPC auto-select > prompt
_resolveVpc() {
  if [[ -n "${_VPC_OVERRIDE:-}" ]]; then
    _VPC_ID="$_VPC_OVERRIDE"
    echo "Using VPC: $_VPC_ID (from command line)"
    return
  fi

  if [[ -n "${EC_VPC_ID:-}" ]]; then
    _VPC_ID="$EC_VPC_ID"
    echo "Using VPC: $_VPC_ID (from EC_VPC_ID)"
    return
  fi

  # Discover VPCs, optionally filtered by tag Name
  local _vpcFilters=()
  [[ -n "${EC_VPC_FILTER:-}" ]] && _vpcFilters+=("Name=tag:Name,Values=$EC_VPC_FILTER")

  local _vpcData
  _vpcData=$(aws --output text ec2 describe-vpcs \
    ${_vpcFilters:+--filters "${_vpcFilters[@]}"} \
    --query "Vpcs[*].[VpcId,CidrBlock,Tags[?Key=='Name']|[0].Value,IsDefault]" 2>/dev/null) || true

  if [[ $? -ne 0 ]] || [[ -z "$_vpcData" && ${#_vpcFilters[@]} -gt 0 ]]; then
    : # empty is handled below
  fi

  local _vpcIds=() _vpcLines=()
  while IFS=$'\t' read -r _vid _cidr _name _default; do
    _vpcIds+=("$_vid")
    _vpcLines+=("$_vid  $_cidr  ${_name:-<no name>}${_default:+  [default]}")
  done <<< "$_vpcData"

  local _count=${#_vpcIds[@]}

  if [[ $_count -eq 0 ]]; then
    echo "ERROR: No VPCs found${EC_VPC_FILTER:+ matching filter '$EC_VPC_FILTER'}."
    exit 1
  elif [[ $_count -eq 1 ]]; then
    _VPC_ID="${_vpcIds[0]}"
    echo "Using VPC: $_VPC_ID (only VPC available)"
  else
    echo "Multiple VPCs found. Select one:"
    local _i=1
    for _line in "${_vpcLines[@]}"; do
      echo "  $_i) $_line"
      ((_i++))
    done
    read -rp "Choice [1-$_count]: " _vpcChoice
    if [[ "$_vpcChoice" -ge 1 && "$_vpcChoice" -le $_count ]]; then
      _VPC_ID="${_vpcIds[$((_vpcChoice - 1))]}"
      echo "Using VPC: $_VPC_ID"
      read -rp "Save '$_VPC_ID' as default in $userConf? [y]es / [n]o: " _saveVpc
      case $_saveVpc in
        y|Y|yes)
          mkdir -p "$HOME/.config/ecTools"
          echo "EC_VPC_ID=\"$_VPC_ID\"" >> "$userConf"
          echo "EC_VPC_ID saved to $userConf"
          ;;
      esac
    else
      echo "Invalid choice, exiting."
      exit 1
    fi
  fi
}

# Parse options (gnu-getopt loaded by tools.rc on macOS)
ARGS=$(getopt --name ecLaunch \
              --options 't:o:a:hp:s:v:T:n' \
              --longoptions 'type:,owner:,ami:,help,profile:,subnet:,vpc:,tag:,replace-tags,dry-run,list-subnets' -- "$@")
if [[ "$?" -gt 0 ]]; then usage; fi
eval "set -- $ARGS"
_CLI_TAGS=""
_REPLACE_TAGS=0
_DRY_RUN=0
while true; do
    case $1 in
      -t|--type)         EC_INSTANCE_TYPE=$2; shift 2 ;;
      -o|--owner)        _OWNERTAG=$2;        shift 2 ;;
      -a|--ami)          _IMAGEID=$2;         shift 2 ;;
      -s|--subnet)       _SUBNET_OVERRIDE=$2; shift 2 ;;
      -v|--vpc)          _VPC_OVERRIDE=$2;    shift 2 ;;
      -T|--tag)          _CLI_TAGS="${_CLI_TAGS:+$_CLI_TAGS,}$2"; shift 2 ;;
      --replace-tags)    _REPLACE_TAGS=1; shift ;;
      -n|--dry-run)      _DRY_RUN=1; shift ;;
      --list-subnets)    _resolveVpc; _listSubnets; exit 0 ;;
      -p|--profile)      shift 2 ;;
      -h|--help)         usage ;;
      --)                shift; break ;;
      *)                 echo "option $1 is unknown"; usage ;;
    esac
done

# Resolve VPC first, then subnet within it
_resolveVpc

# Resolve subnet
if [[ -n "${_SUBNET_OVERRIDE:-}" ]]; then
  subnet="$_SUBNET_OVERRIDE"
  echo "Using subnet: $subnet (from command line)"
elif [[ -n "${EC_SUBNET_ID:-}" ]]; then
  subnet="$EC_SUBNET_ID"
  echo "Using subnet: $subnet (from EC_SUBNET_ID)"
else
  # Pick a random subnet matching EC_SUBNET_FILTER
  _subnetList=()
  while IFS=$'\t' read -r _sid _az _cidr _name; do
    _subnetList+=("$_sid")
  done < <(_getSubnets)

  subnetCount=${#_subnetList[@]}
  if [[ $subnetCount -eq 0 ]]; then
    echo "No subnets found matching filter '${EC_SUBNET_FILTER:-*rivate*}'"
    echo ""
    _listSubnets
    exit 1
  fi
  subnet="${_subnetList[$((RANDOM % subnetCount))]}"
  echo "Using subnet: $subnet (randomly selected from $subnetCount matching)"
fi

_IMAGEID="${_IMAGEID:-2023}"

function promptInstanceType() {
  local prompt=$1
  local value
  echo "Available instance types (current generation):"
  aws ec2 describe-instance-types \
    --filters "Name=current-generation,Values=true" \
    --query "sort_by(InstanceTypes, &InstanceType)[].InstanceType" \
    --output table
  read -rp "$prompt" value
  if [[ -z "$value" ]]; then
    echo "EC_INSTANCE_TYPE is required, exiting."
    exit 1
  fi
  read -rp "Save '$value' as default in $userConf? [y]es / [n]o (just this time): " saveChoice
  case $saveChoice in
    y|Y|yes)
      mkdir -p "$HOME/.config/ecTools"
      echo "EC_INSTANCE_TYPE=\"$value\"" >> "$userConf"
      echo "EC_INSTANCE_TYPE saved to $userConf"
      ;;
    *)
      echo "Using '$value' for this session only."
      ;;
  esac
  export EC_INSTANCE_TYPE="$value"
}

# Resolve EC_INSTANCE_TYPE: -t flag takes precedence, then conf (single or multi-value)
if [[ -z "$EC_INSTANCE_TYPE" ]]; then
  echo "EC_INSTANCE_TYPE is not set in any configuration file or provided as an argument."
  promptInstanceType "Enter the instance type: "
else
  # Count words in EC_INSTANCE_TYPE
  read -ra _typeList <<< "$EC_INSTANCE_TYPE"
  if [[ ${#_typeList[@]} -gt 1 ]]; then
    echo "Multiple instance types configured. Select one:"
    _i=1
    for _t in "${_typeList[@]}"; do
      echo "  $_i) $_t"
      ((_i++))
    done
    read -rp "Choice [1-$((${#_typeList[@]}))]: " _typeChoice
    if [[ "$_typeChoice" -ge 1 && "$_typeChoice" -le ${#_typeList[@]} ]]; then
      EC_INSTANCE_TYPE="${_typeList[$((_typeChoice - 1))]}"
    else
      echo "Invalid choice, exiting."
      exit 1
    fi
  fi
fi

# Validate EC_INSTANCE_TYPE exists in AWS
_validInstance=$(aws ec2 describe-instance-types \
  --instance-types "$EC_INSTANCE_TYPE" \
  --query "InstanceTypes[].InstanceType" \
  --output text 2>/dev/null) || true

if [[ -z "$_validInstance" ]]; then
  echo "WARNING: Instance type '$EC_INSTANCE_TYPE' not found in region ${AWS_DEFAULT_REGION}."
  promptInstanceType "Enter a valid instance type: "
  _validInstance=$(aws ec2 describe-instance-types \
    --instance-types "$EC_INSTANCE_TYPE" \
    --query "InstanceTypes[].InstanceType" \
    --output text 2>/dev/null) || true
  if [[ -z "$_validInstance" ]]; then
    echo "Instance type '$EC_INSTANCE_TYPE' still not found, exiting."
    exit 1
  fi
fi

_PROJECT="${EC_PROJECT:-}"
if [[ -z "$_PROJECT" ]]; then
  echo "EC_PROJECT is not set. A project tag is required for cost allocation."
  promptAndSave "EC_PROJECT" "Enter the project name: "
  _PROJECT="$EC_PROJECT"
fi

_OWNERTAG="${_OWNERTAG:-$(whoami)}"

# Get Requested instance information:
while read -r Architecture vcpu Memory StorageTotal StorageDiskSize StorageDiskCount StorageDiskNVME GPU_Manufacturer GPU_Name GPU_Number GPU_Memory FPGA_Manufacturer FPGA_Name FPGA_Number FPGA_Memory INF_Manufacturer INF_Name INF_Number SupportedVirtualizationType; do

  echo "Requested $Architecture Instance with $vcpu vCPU, $Memory Memory"
  if [[ $StorageDiskCount -gt 0 ]]; then
    echo "The $EC_INSTANCE_TYPE has $StorageDiskCount x $StorageDiskSize GB disks, Total of $StorageTotal of instance storage, NVME is $StorageDiskNVME"
    for ((disk = 1; disk <= StorageDiskCount; disk++)); do
      printf -v DiskLetter "\x$(printf %x $((disk+97)))"
      ephemeral=$((disk - 1))
      if [[ $disk -eq 1 ]]; then
        DiskMapping="DeviceName=/dev/sd$DiskLetter,VirtualName=ephemeral$ephemeral"
      else
        DiskMapping="$DiskMapping DeviceName=/dev/sd$DiskLetter,VirtualName=ephemeral$ephemeral"
      fi
    done
    extraParams="--block-device-mappings $DiskMapping"
  else
    echo "The $EC_INSTANCE_TYPE has no instance storage"
  fi

  accelerator="None"
  if [[ $GPU_Manufacturer != "None" ]]; then
    accelerator="$GPU_Manufacturer"
    echo "and $GPU_Number $GPU_Manufacturer $GPU_Name and $GPU_Memory Memory"
  elif [[ $FPGA_Manufacturer != "None" ]]; then
    accelerator="FPGA"
    echo "and $FPGA_Number $FPGA_Manufacturer $FPGA_Name and $FPGA_Memory Memory"
  elif [[ $INF_Manufacturer != "None" ]]; then
    accelerator="Inference"
    echo "and $INF_Number $INF_Manufacturer $INF_Name"
  fi

  case $Architecture in
    i386 | x86_64)
      case $accelerator in
        NVIDIA | Inference)
          ## For accelerated see https://aws.amazon.com/releasenotes/aws-deep-learning-ami-catalog/
          if [[ $_IMAGEID == "2023" ]]; then
            _IMAGEID=$(aws ssm get-parameter --name /aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-x86_64 \
              --query Parameter.Value --output text 2>/dev/null) || true
          else
            _IMAGEID=$(aws ec2 describe-images \
              --owners amazon \
              --filters 'Name=name,Values=Deep?Learning?Base?AMI?(Amazon?Linux?2)?Version???.?' "Name=state,Values=available" \
              --query "reverse(sort_by(Images,&CreationDate))[:1].ImageId" --output text 2>/dev/null) || true
          fi
          if [[ -z "$_IMAGEID" || "$_IMAGEID" == "None" ]]; then
            echo "ERROR: Could not resolve AMI for $accelerator on $Architecture. Exiting."
            exit 1
          fi
          _NAMESUFFIX="-GPU"
          ;;
        None)
          if [[ $_IMAGEID == "2023" ]]; then
            _IMAGEID=$(aws ssm get-parameter --name /aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-x86_64 \
              --query Parameter.Value --output text 2>/dev/null) || true
          else
            _IMAGEID=$(aws ec2 describe-images \
              --owners amazon \
              --filters "Name=name,Values=amzn2-ami-$SupportedVirtualizationType-2.0.????????.?-$Architecture-gp2" "Name=state,Values=available" \
              --query "reverse(sort_by(Images,&CreationDate))[:1].[ImageId]" --output text 2>/dev/null) || true
          fi
          if [[ -z "$_IMAGEID" || "$_IMAGEID" == "None" ]]; then
            echo "ERROR: Could not resolve AMI for $Architecture. Exiting."
            exit 1
          fi
          _NAMESUFFIX="-CPU"
          ;;
        *)
          echo "No support for $accelerator on $Architecture yet, exiting"
          exit 0
          ;;
      esac
      ;;
    arm64)      echo "No Support for arm64 yet, exiting";    exit 0 ;;
    x86_64_mac) echo "No Support for Mac X64 yet, exiting"; exit 0 ;;
    *)          echo "Unknown architecture, exiting";        exit 0 ;;
  esac

done < <(aws --output text ec2 describe-instance-types \
    --instance-types "$EC_INSTANCE_TYPE" \
    --query "InstanceTypes[].[ProcessorInfo.SupportedArchitectures[0],VCpuInfo.DefaultVCpus,MemoryInfo.SizeInMiB,InstanceStorageInfo.TotalSizeInGB,InstanceStorageInfo.Disks[0].SizeInGB,InstanceStorageInfo.Disks[0].Count,InstanceStorageInfo.NvmeSupport,GpuInfo.Gpus[0].Manufacturer,GpuInfo.Gpus[0].Name,GpuInfo.Gpus[0].Count,GpuInfo.TotalGpuMemoryInMiB,FpgaInfo.Fpgas[0].Manufacturer,FpgaInfo.Fpgas[0].Name,FpgaInfo.Fpgas[0].Count,FpgaInfo.TotalFpgaMemoryInMiB,InferenceAcceleratorInfo.Accelerators[0].Manufacturer,InferenceAcceleratorInfo.Accelerators[0].Name,InferenceAcceleratorInfo.Accelerators[0].Count,SupportedVirtualizationTypes[0]]")

if [[ -n $EC_LAUNCH_TEMPLATE_VERSION ]]; then
  _LAUNCHTEMPLATEVERSION=",Version=$EC_LAUNCH_TEMPLATE_VERSION"
fi

# Check for ecUserScript in the same directories as the conf file
_USERDATA_ARG=""
for _confDir in "/etc/ecTools" "$HOME/.config/ecTools"; do
  if [[ -f "$_confDir/ecUserScript" ]]; then
    _USERSCRIPT="$_confDir/ecUserScript"
  fi
done
if [[ -n "$_USERSCRIPT" ]]; then
  echo "Using user data script: $_USERSCRIPT"
  _USERDATA_ARG="--user-data file://$_USERSCRIPT"
fi

# Build extra tags from conf (EC_EXTRA_TAGS) and/or command line (-T flags)
# EC_EXTRA_TAGS format: "Key=Value,Key2=Value2"
# --replace-tags replaces conf tags entirely with CLI tags
if [[ $_REPLACE_TAGS -eq 1 ]]; then
  _extraTagsRaw="${_CLI_TAGS:-}"
else
  _extraTagsRaw="${EC_EXTRA_TAGS:-}"
  [[ -n "$_CLI_TAGS" ]] && _extraTagsRaw="${_extraTagsRaw:+$_extraTagsRaw,}$_CLI_TAGS"
fi

# Convert "Key=Value,Key2=Value2" → "{Key=Key,Value=Value},{Key=Key2,Value=Value2}"
_extraTagJson=""
if [[ -n "$_extraTagsRaw" ]]; then
  IFS=',' read -ra _tagPairs <<< "$_extraTagsRaw"
  for _pair in "${_tagPairs[@]}"; do
    _k="${_pair%%=*}"
    _v="${_pair#*=}"
    _extraTagJson="${_extraTagJson:+$_extraTagJson,}{Key=$_k,Value=$_v}"
  done
  _extraTagJson=",$_extraTagJson"
fi

# shellcheck disable=SC2086
if [[ $_DRY_RUN -eq 1 ]]; then
  echo "[dry-run] aws ec2 run-instances $extraParams \\"
  echo "  ${_LAUNCHTEMPLATEARG:+$_LAUNCHTEMPLATEARG \\}"
  echo "  ${_USERDATA_ARG:+$_USERDATA_ARG \\}"
  echo "  --image-id \"$_IMAGEID\" \\"
  echo "  --instance-type \"$EC_INSTANCE_TYPE\" \\"
  echo "  --subnet-id \"$subnet\" --no-associate-public-ip-address \\"
  echo "  --hibernation-options Configured=true \\"
  echo "  --block-device-mappings \"Ebs={VolumeSize=30},DeviceName=/dev/xvda\" \\"
  echo "  --tag-specifications \\"
  echo "    \"ResourceType=instance,Tags=[{Key=Name,Value=${EC_NAME_PREFIX}${_OWNERTAG}${_NAMESUFFIX}},{Key=owner,Value=$_OWNERTAG},{Key=creator,Value=$_OWNERTAG},{Key=project,Value=$_PROJECT},{Key=Project,Value=$_PROJECT}${_extraTagJson}]\" \\"
  echo "    \"ResourceType=volume,Tags=[{Key=Name,Value=${EC_NAME_PREFIX}${_OWNERTAG}${_NAMESUFFIX}},{Key=owner,Value=$_OWNERTAG},{Key=creator,Value=$_OWNERTAG},{Key=project,Value=$_PROJECT},{Key=Project,Value=$_PROJECT}${_extraTagJson}]\""
  exit 0
fi

InstanceID=$(aws --output text ec2 run-instances $extraParams \
  ${_LAUNCHTEMPLATEARG:+$_LAUNCHTEMPLATEARG} \
  ${_USERDATA_ARG:+$_USERDATA_ARG} \
  --image-id "$_IMAGEID" \
  --instance-type "$EC_INSTANCE_TYPE" \
  --subnet-id "$subnet" --no-associate-public-ip-address \
  --hibernation-options Configured=true \
  --block-device-mappings "Ebs={VolumeSize=30},DeviceName=/dev/xvda" \
  --tag-specifications \
    "ResourceType=instance,Tags=[{Key=Name,Value=${EC_NAME_PREFIX}${_OWNERTAG}${_NAMESUFFIX}},{Key=owner,Value=$_OWNERTAG},{Key=creator,Value=$_OWNERTAG},{Key=project,Value=$_PROJECT},{Key=Project,Value=$_PROJECT}${_extraTagJson}]" \
    "ResourceType=volume,Tags=[{Key=Name,Value=${EC_NAME_PREFIX}${_OWNERTAG}${_NAMESUFFIX}},{Key=owner,Value=$_OWNERTAG},{Key=creator,Value=$_OWNERTAG},{Key=project,Value=$_PROJECT},{Key=Project,Value=$_PROJECT}${_extraTagJson}]" \
  --query "Instances[*].[InstanceId]") || true

if [[ -z "$InstanceID" ]]; then
  echo "ERROR: run-instances failed or returned no instance ID. Check AWS CLI output above for details."
  exit 1
fi

echo "Launching Image $_IMAGEID as Instance $InstanceID"
