#!/usr/bin/env bash
# shellcheck source=./tools.rc
_TOOLS_RC="${0%/*}/tools.rc"
if [[ ! -f "$_TOOLS_RC" ]]; then
  echo "ERROR: tools.rc not found at $_TOOLS_RC"
  echo "Ensure tools.rc is in the same directory as ecConnect."
  exit 1
fi
source "$_TOOLS_RC"

if [[ -z "$EC_SSH_KEY" ]]; then
  echo "EC_SSH_KEY is not set. Select a private key to use:"

  # List private keys in ~/.ssh (files without .pub extension that have a matching .pub)
  _keys=()
  for _k in "$HOME/.ssh/"*; do
    [[ -f "$_k" && -f "${_k}.pub" ]] && _keys+=("$_k")
  done

  if [[ ${#_keys[@]} -eq 0 ]]; then
    echo "  No private keys found in ~/.ssh (looked for files with a matching .pub)."
  fi

  _i=1
  for _k in "${_keys[@]}"; do
    echo "  $_i) $_k"
    ((_i++))
  done
  echo "  $_i) Other (manual input)"

  read -rp "Choice [1-$_i]: " _keyChoice
  if [[ "$_keyChoice" -ge 1 && "$_keyChoice" -lt $_i ]]; then
    keyPath="${_keys[$((_keyChoice - 1))]}"
  elif [[ "$_keyChoice" -eq $_i ]]; then
    read -rp "Enter the path to your SSH key: " keyPath
    if [[ -z "$keyPath" ]]; then
      echo "No SSH key provided, exiting."
      exit 1
    fi
    if [[ ! -f "${keyPath/#\~/$HOME}" ]]; then
      echo "SSH key not found: $keyPath"
      exit 1
    fi
  else
    echo "Invalid choice, exiting."
    exit 1
  fi

  export EC_SSH_KEY="-i $keyPath"
  read -rp "Save '$keyPath' as default in $userConf? [y]es / [n]o (just this time): " _saveKey
  case $_saveKey in
    y|Y|yes)
      mkdir -p "$HOME/.config/ecTools"
      echo "export EC_SSH_KEY=\"-i $keyPath\"" >> "$userConf"
      echo "EC_SSH_KEY saved to $userConf"
      ;;
    *) echo "Using '$keyPath' for this session only." ;;
  esac
fi

if [[ -z "$EC_IP_CONNECTION" ]]; then
  export EC_IP_CONNECTION="private"
  mkdir -p "$HOME/.config/ecTools"
  echo "export EC_IP_CONNECTION=\"private\"" >> "$userConf"
  echo "EC_IP_CONNECTION defaulted to 'private' and saved to $userConf"
fi

# Usage output
usage() {
  echo "Usage: ${BASH_SOURCE[0]} [ -L | --forward SPEC ] [ -f | --fork ] [ -u | --user USER ] [ -o | --owner OWNER ] [ -n | --dry-run ] [ -p | --profile PROFILE ] [ -h | --help ] [ public | private | ssm ] [ random | i-<id> | <number> | list ]
        -L | --forward SPEC      SSH port forward, e.g. 8080:localhost:80 (may be repeated)
        -f | --fork              Fork SSH into background (-f -N) after forwarding
        -u | --user USER         SSH username (overrides EC_SSH_USER from config)
        -o | --owner OWNER       Filter instances by owner tag value
        -n | --dry-run           Print the ssh command that would be run without connecting
        -p | --profile PROFILE   AWS config profile to use (overrides EC_AWS_PROFILE from config)
        -h | --help              Show this help
        public | private | ssm   Override EC_IP_CONNECTION from config"
  exit 0
}

# Parse options (gnu-getopt loaded by tools.rc on macOS)
_ARGS=$(getopt --name ecConnect \
               --options 'L:fhu:o:np:' \
               --longoptions 'forward:,fork,help,user:,owner:,dry-run,profile:' -- "$@") || usage
eval "set -- $_ARGS"

_SSH_FORWARD_ARGS=""
_SSH_FORK=0
_OWNER_FILTER=""
_DRY_RUN=0
while true; do
  case $1 in
    -L|--forward) _SSH_FORWARD_ARGS="$_SSH_FORWARD_ARGS -L $2"; shift 2 ;;
    -f|--fork)    _SSH_FORK=1; shift ;;
    -u|--user)    EC_SSH_USER=$2; shift 2 ;;
    -o|--owner)   _OWNER_FILTER=$2; shift 2 ;;
    -n|--dry-run) _DRY_RUN=1; shift ;;
    -p|--profile) shift 2 ;;  # already handled in tools.rc, skip
    -h|--help)    usage ;;
    --)           shift; break ;;
  esac
done

# Resolve EC_SSH_USER if not set by config or command line
if [[ -z "$EC_SSH_USER" ]]; then
  _localUser=$(whoami)
  _iamUser=$(echo "$_callerArn" | awk -F'/' '{print $NF}')

  echo "EC_SSH_USER is not set. Select the SSH username to use:"
  echo "  1) Local system user: $_localUser"
  echo "  2) IAM/Identity user: $_iamUser"
  echo "  3) Custom entry"
  read -rp "Choice [1/2/3]: " _userChoice
  case $_userChoice in
    1) EC_SSH_USER="$_localUser" ;;
    2) EC_SSH_USER="$_iamUser" ;;
    3) read -rp "Enter SSH username: " EC_SSH_USER
       if [[ -z "$EC_SSH_USER" ]]; then
         echo "No username provided, exiting."
         exit 1
       fi
       ;;
    *) echo "Invalid choice, exiting."; exit 1 ;;
  esac

  read -rp "Save '$EC_SSH_USER' as default in $userConf? [y]es / [n]o (just this time): " _saveUser
  case $_saveUser in
    y|Y|yes)
      mkdir -p "$HOME/.config/ecTools"
      echo "export EC_SSH_USER=\"$EC_SSH_USER\"" >> "$userConf"
      echo "EC_SSH_USER saved to $userConf"
      ;;
    *) echo "Using '$EC_SSH_USER' for this session only." ;;
  esac
  export EC_SSH_USER
fi

function getInstances() {
    local _ownerFilter=""
    [[ -n "$_OWNER_FILTER" ]] && _ownerFilter=" Name=tag:owner,Values=$_OWNER_FILTER"

    case $EC_IP_CONNECTION in
        public)
            # shellcheck disable=SC2086
            aws --output text ec2 describe-instances \
            --filters Name=instance-state-name,Values=running Name=tag:"$EC_TAG_KEY",Values="$EC_TAG_VALUE"$_ownerFilter \
            --query "Reservations[*].Instances[*].[InstanceId,InstanceType,PublicIpAddress,PublicDnsName,Tags[?Key=='Name']|[0].Value]"
        ;;
        private)
            # shellcheck disable=SC2086
            aws --output text ec2 describe-instances \
            --filters Name=instance-state-name,Values=running Name=tag:"$EC_TAG_KEY",Values="$EC_TAG_VALUE"$_ownerFilter \
            --query "Reservations[*].Instances[*].[InstanceId,InstanceType,PrivateIpAddress,PrivateDnsName,Tags[?Key=='Name']|[0].Value]"
        ;;
        ssm)
            # SSM connects by instance ID; IP columns are unused but kept for consistent field count
            # shellcheck disable=SC2086
            aws --output text ec2 describe-instances \
            --filters Name=instance-state-name,Values=running Name=tag:"$EC_TAG_KEY",Values="$EC_TAG_VALUE"$_ownerFilter \
            --query "Reservations[*].Instances[*].[InstanceId,InstanceType,InstanceId,InstanceId,Tags[?Key=='Name']|[0].Value]"
        ;;
        *)
            echo "No IP Connection type defined (EC_IP_CONNECTION == $EC_IP_CONNECTION)"
            exit 1
        ;;
    esac
}

function connectTo() {
    local host=$1
    local num=0

    case $host in
        hostNumber) local hostNumber=$2 ;;
        hostId)     local hostId=$2 ;;
    esac

    while IFS=$'\t' read -r InstanceId InstanceType PublicIpAddress PublicDnsName Name; do
        ((num = num + 1))
        if [[ $host == hostNumber ]] && [[ $hostNumber -eq $num ]]; then
            echo "you selected $hostNumber: $Name is $InstanceId (${InstanceType}) on $PublicDnsName (${PublicIpAddress})" && break
        elif [[ $host == hostId ]] && [[ $hostId == "$InstanceId" ]]; then
            echo "you selected $InstanceId: $Name (${InstanceType}) on $PublicDnsName (${PublicIpAddress})" && break
        fi
    done < <(getInstances)

    if [[ -z "$InstanceId" ]]; then
        echo "ERROR: No matching instance found."
        exit 1
    fi

    local PARAMS=""
    if [[ -n "$EC_SSH_KEY" ]];        then PARAMS="$EC_SSH_KEY"; fi
    if [[ -n "$EC_SSH_FORWARD" ]];    then PARAMS="$PARAMS $EC_SSH_FORWARD"; fi
    if [[ -n "$_SSH_FORWARD_ARGS" ]]; then PARAMS="$PARAMS $_SSH_FORWARD_ARGS"; fi

    if [[ $_DRY_RUN -eq 1 ]]; then
        if [[ $EC_IP_CONNECTION == ssm ]]; then
            local _proxy="aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters portNumber=%p"
            echo "[dry-run] ssh -tt $PARAMS -o ProxyCommand='$_proxy' $EC_SSH_USER@$InstanceId"
        elif [[ $_SSH_FORK -eq 1 ]]; then
            echo "[dry-run] ssh -f -N $PARAMS $EC_SSH_USER@$PublicIpAddress"
        else
            echo "[dry-run] ssh -tt $PARAMS $EC_SSH_USER@$PublicIpAddress"
        fi
        return
    fi

    if [[ $EC_IP_CONNECTION == ssm ]]; then
        # SSH over SSM — requires aws-session-manager-plugin installed
        local _proxy="aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters portNumber=%p"
        local _ssmErrFile; _ssmErrFile=$(mktemp)
        PARAMS="$PARAMS -o ProxyCommand='$_proxy'"
        if [[ $_SSH_FORK -eq 1 ]]; then
            # shellcheck disable=SC2086
            ssh -f -N $PARAMS "$EC_SSH_USER"@"$InstanceId" 2>"$_ssmErrFile"
        else
            # shellcheck disable=SC2086
            ssh -tt $PARAMS "$EC_SSH_USER"@"$InstanceId" </dev/tty 2>"$_ssmErrFile"
        fi
        local _rc=$?
        if [[ $_rc -ne 0 ]] && grep -q "TargetNotConnected\|not connected\|Connection closed by UNKNOWN" "$_ssmErrFile" 2>/dev/null; then
            echo ""
            echo "ERROR: Could not connect to $InstanceId via Session Manager."
            echo ""
            echo "Possible causes:"
            echo "  1. SSM Agent is not running on the instance."
            echo "     Fix: sudo systemctl start amazon-ssm-agent"
            echo "  2. The instance has no IAM role with SSM permissions."
            echo "     Fix: attach the AmazonSSMManagedInstanceCore policy to the instance role."
            echo "  3. The instance cannot reach the SSM endpoints (no internet/VPC endpoint)."
            echo "     Fix: ensure VPC endpoints for ssm, ssmmessages, ec2messages exist, or allow outbound HTTPS."
            echo "  4. The instance is stopped, terminated, or not yet fully started."
            echo "     Fix: verify the instance is running: aws ec2 describe-instances --instance-ids $InstanceId"
            echo "  5. Your IAM identity lacks ssm:StartSession permission for this instance."
            echo "     Fix: check your IAM policy includes ssm:StartSession on the target resource."
            rm -f "$_ssmErrFile"
            exit 1
        fi
        rm -f "$_ssmErrFile"
    elif [[ $_SSH_FORK -eq 1 ]]; then
        # shellcheck disable=SC2086
        ssh -f -N $PARAMS "$EC_SSH_USER"@"$PublicIpAddress"
    elif [[ -n $PARAMS ]]; then
        # shellcheck disable=SC2086
        ssh -tt $PARAMS "$EC_SSH_USER"@"$PublicIpAddress" </dev/tty
    else
        ssh -tt "$EC_SSH_USER"@"$PublicIpAddress" </dev/tty
    fi
}

if [[ -z $1 ]] || [[ $1 == "public" ]] || [[ $1 == "private" ]] || [[ $1 == "ssm" ]]; then
    case $1 in
        public)  EC_IP_CONNECTION=public ;;
        private) EC_IP_CONNECTION=private ;;
        ssm)     EC_IP_CONNECTION=ssm ;;
    esac
    num=0
    echo "0:  Any host (random selection)"
    while IFS=$'\t' read -r InstanceId InstanceType PublicIpAddress PublicDnsName Name; do
        ((num = num + 1))
        echo "$num:  $Name is $InstanceId (${InstanceType}) on $PublicDnsName (${PublicIpAddress})"
    done < <(getInstances)
    if [[ $num -eq 0 ]]; then
        echo "No running instances found matching the current filter."
        exit 1
    fi
    echo "x:  Exit"
    while true; do
        read -rp 'Select host (0 for a random host, x to exit): ' hostNum
        if [[ $hostNum != "x" ]] && [[ $hostNum -gt $num ]]; then
            echo "Enter a value between 0 and $num or x"
        elif [[ $hostNum == "x" ]]; then
            echo "goodbye"
            exit 0
        else
            if [[ $hostNum -eq 0 ]]; then
                connectTo hostNumber $((1 + RANDOM % num))
            else
                connectTo hostNumber "$hostNum"
            fi
            exit 0
        fi
    done
else
    case $2 in
        public)  EC_IP_CONNECTION=public ;;
        private) EC_IP_CONNECTION=private ;;
        ssm)     EC_IP_CONNECTION=ssm ;;
    esac
    case $1 in
        random)
            num=0
            while IFS=$'\t' read -r InstanceId; do
                ((num = num + 1))
            done < <(getInstances)
            if [[ $num -eq 0 ]]; then
                echo "No running instances found matching the current filter."
                exit 1
            fi
            connectTo hostNumber $((1 + RANDOM % num))
        ;;
        i-*)
            connectTo hostId "$1"
        ;;
        [1-9])
            connectTo hostNumber "$1"
        ;;
        list)
            case $2 in
                public)  EC_IP_CONNECTION=public ;;
                private) EC_IP_CONNECTION=private ;;
                ssm)     EC_IP_CONNECTION=ssm ;;
            esac
            getInstances
        ;;
        *)
            echo "Unknown option"
            exit 1
        ;;
    esac
fi
